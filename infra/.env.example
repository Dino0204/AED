# GSM SV에 배포할 때 사용할 환경변수. 실제 .env는 .gitignore 권장.

# n8n이 자기 webhook URL을 생성할 때 쓰는 hostname.
# 예: aed-n8n.gsmsv.site, dino-aed.gsmsv.site
AED_HOST=aed-n8n.example.com

# Google AI Studio에서 발급. n8n의 HTTP Request 노드가 expression으로 참조.
GEMINI_API_KEY=AIza-your-key-here

# webhook secret은 n8n credential (Header Auth: x-aed-signature)로 등록.
# Vercel Next.js의 N8N_WEBHOOK_SECRET 과 동일 값이어야 함.
