{
  "manifest_version": 3,
  "name": "AED - Portfolio Curator",
  "version": "1.0.0",
  "description": "어떤 페이지에서든 포트폴리오 메모 추가, AI 제안 검토, 결정 기록",
  "permissions": [
    "sidePanel",
    "storage",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/index.ts-loader-BVjkqJ3U.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "action": {
    "default_title": "AED Portfolio Curator"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "assets/source-DMU6Yiac.js",
        "assets/index.ts-ztaiFIAp.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
